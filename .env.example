DATABASE_URL=postgres://admin:root@localhost:5432/aistudio
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
REPLICATE_API_TOKEN=r8_replace-with-your-replicate-api-token
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=aistudio
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_TTL_SECONDS=86400

# Studio generations persistence & async generation
# Enable the non-blocking, DB-backed async generation flow. When false, the
# generate route persists outputs synchronously (Phase 1 behavior).
STUDIO_ASYNC_GENERATIONS=false
# Run the generations worker loop inside the app process (via instrumentation).
# Set to false when running a dedicated worker process.
STUDIO_WORKER_IN_PROCESS=true
# Parallel jobs processed per worker poll cycle.
STUDIO_WORKER_CONCURRENCY=4
# Mark generations stuck in `generating` past this many minutes as failed.
STUDIO_GENERATION_TIMEOUT_MINUTES=10
# Delete input assets (studio-uploads/*) from S3 once a generation finishes.
STUDIO_DELETE_INPUTS_AFTER_GENERATION=true
# Output URL strategy for stored media (signed | proxy).
STUDIO_OUTPUT_URL_MODE=signed
