DATABASE_URL=postgres://admin:root@localhost:5432/aistudio
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
REPLICATE_API_TOKEN=r8_replace-with-your-replicate-api-token
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=aistudio
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_TTL_SECONDS=86400

# Redis/BullMQ runtime queue
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=open-generative-ai

# Studio queue
STUDIO_QUEUE_NAME=studio-generations
STUDIO_WORKER_CONCURRENCY=4
STUDIO_JOB_ATTEMPTS=3
STUDIO_JOB_BACKOFF_MS=5000

# Workflow queue
WORKFLOW_QUEUE_NAME=workflow-runs
WORKFLOW_WORKER_CONCURRENCY=2
WORKFLOW_JOB_ATTEMPTS=2
WORKFLOW_JOB_BACKOFF_MS=5000

# Workflow Architect queue
WORKFLOW_ARCHITECT_QUEUE_NAME=workflow-architect
WORKFLOW_ARCHITECT_WORKER_CONCURRENCY=1
WORKFLOW_ARCHITECT_JOB_ATTEMPTS=1
WORKFLOW_ARCHITECT_JOB_BACKOFF_MS=5000

# Design Agent queue
DESIGN_AGENT_QUEUE_NAME=design-agent-jobs
DESIGN_AGENT_WORKER_CONCURRENCY=2
DESIGN_AGENT_JOB_ATTEMPTS=2
DESIGN_AGENT_JOB_BACKOFF_MS=5000

# Event channel
EVENT_TRANSPORT=sse
EVENT_REDIS_CHANNEL_PREFIX=oga-events

# Optional Studio concurrency limits
# 0 disables provider caps; set to match provider account limits in production.
REPLICATE_MAX_ACTIVE_JOBS=0
MUAPI_MAX_ACTIVE_JOBS=0
STUDIO_PER_USER_CONCURRENCY_LIMIT=2
STUDIO_CONCURRENCY_LEASE_MS=3600000
STUDIO_CONCURRENCY_RETRY_DELAY_MS=1000

# Studio generations persistence & async generation
# Enable the non-blocking, Redis/BullMQ-backed async generation flow.
STUDIO_ASYNC_GENERATIONS=true
# Runtime samples are collected for successful Replicate predictions. Set true
# only after validating history accuracy to include approximate ETAs in responses.
REPLICATE_RUNTIME_ESTIMATES_ENABLED=false
# Delete input assets (studio-uploads/*) from S3 once a generation finishes.
STUDIO_DELETE_INPUTS_AFTER_GENERATION=true
# Output URL strategy for stored media (signed | proxy).
STUDIO_OUTPUT_URL_MODE=signed
